{
  "expo": {
    "name": "PitchNest",
    "slug": "pitchnest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "pitchnest",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0ea5e9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pitchnest.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PitchNest uses your camera so AI investors can see you during live pitch practice.",
        "NSMicrophoneUsageDescription": "PitchNest uses your microphone so you can speak to AI investors during pitch sessions.",
        "NSPhotoLibraryUsageDescription": "PitchNest lets you upload pitch deck PDFs from your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.pitchnest.app",
      "adaptiveIcon": {
        "backgroundColor": "#0ea5e9",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "PitchNest uses your camera during live pitch practice.",
          "microphonePermission": "PitchNest uses your microphone during live pitch practice.",
          "recordAudioAndroid": true
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "pitchnest-mobile"
      }
    }
  }
}
