# ── Supabase ──
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Auth ──
JWT_SECRET=your-strong-random-secret-here

# ── Google Sign-In (optional — enables "Continue with Google") ──
# OAuth 2.0 Web client id from Google Cloud Console. Must match the frontend's
# VITE_GOOGLE_CLIENT_ID. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=

# ── CORS (comma-separate multiple origins in production) ──
ALLOWED_ORIGIN=http://localhost:5174
# Extra allowed origins beyond the built-in defaults (comma-separated). Lets you
# add a new deploy/preview domain without a code change.
CORS_EXTRA_ORIGINS=

# ── Storage ──
# Supabase Storage bucket for uploaded media (decks, pitch videos, avatars).
SUPABASE_STORAGE_BUCKET=pitchnest-media

# ── Azure OpenAI (text generation — required for live pitch) ──
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Azure Speech (TTS — required for panel voices) ──
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# ── Mail (SMTP — verification & password-reset emails) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
CLIENT_URL=http://localhost:5174
# Verified sender identity for transactional email (Resend).
EMAIL_FROM=PitchNest <hello@pitchnest.app>

# ── Optional fallback (if not using Azure OpenAI) ──
OPENAI_API_KEY=

# ── Legacy Gemini (only needed if re-enabling liveSocket.ts) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest

# ── Server ──
PORT=3000
NODE_ENV=development
