# WebSocket backend URL (required when frontend is hosted separately, e.g. Vercel)
VITE_WS_BACKEND_URL=wss://pitchnest-live.onrender.com

# Google Sign-In (optional — enables "Continue with Google"). OAuth 2.0 Web
# client id from Google Cloud Console; must match the backend's GOOGLE_CLIENT_ID.
# In production set this in your host's build env (e.g. Vercel), not just .env.local.
VITE_GOOGLE_CLIENT_ID=
